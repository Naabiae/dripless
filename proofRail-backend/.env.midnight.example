# Midnight Smart Contract Environment Variables

# ====================================================================
# WALLET CONFIGURATION
# ====================================================================

# Your Midnight wallet seed (64 hex characters)
# Generate with: npm run midnight:generate-wallet
# ⚠️  KEEP THIS SECURE - DO NOT COMMIT TO VERSION CONTROL
MIDNIGHT_WALLET_SEED=

# ====================================================================
# PROOF PROVIDER CONFIGURATION
# ====================================================================

# URL of the Midnight Proof Server
# Default (Preprod): https://proof-server.preprod.midnight.network/api/proof
# Mainnet: https://proof-server.midnight.network/api/proof
# Local: http://localhost:6300/api/proof
PROOF_PROVIDER_URL=https://proof-server.preprod.midnight.network/api/proof

# ====================================================================
# NETWORK CONFIGURATION
# ====================================================================

# Network to deploy to
# Options: TestnetPreprod, Mainnet
MIDNIGHT_NETWORK=TestnetPreprod

# ====================================================================
# CONTRACT ADDRESSES (After Deployment)
# ====================================================================

# Generated automatically by npm run midnight:deploy
# Update these after successful deployment
MIDNIGHT_KYC_CONTRACT_ADDRESS=
MIDNIGHT_ESCROW_CONTRACT_ADDRESS=

# ====================================================================
# OPTIONAL: DEPLOYMENT CONFIGURATION
# ====================================================================

# Set to true to enable verbose logging
MIDNIGHT_DEBUG=false

# Timeout for proof generation (in milliseconds)
PROOF_GENERATION_TIMEOUT=300000

# Gas limit for contract calls (if applicable)
MIDNIGHT_GAS_LIMIT=50000
